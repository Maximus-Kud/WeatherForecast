name: dockercompose15081403233701691846
services:
  db:
    container_name: mssql
    environment:
      ACCEPT_EULA: "Y"
      SA_PASSWORD: VeryStrongPassword123!
    image: mcr.microsoft.com/mssql/server:2022-latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 1433
        published: "1433"
        protocol: tcp
    volumes:
      - type: volume
        source: mssql_data
        target: /var/opt/mssql
        volume: {}
  weatherforecast.api:
    build:
      context: D:\Visual Studio Projects\Docker\WeatherForecast\WeatherForecast.API
      dockerfile: Dockerfile
    depends_on:
      db:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
    image: weatherforecastapi
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\Maximus\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\Maximus\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\Maximus\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\Maximus\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind: {}
  weatherforecast.web:
    build:
      context: D:\Visual Studio Projects\Docker\WeatherForecast\WeatherForecast.Web
      dockerfile: Dockerfile
    environment:
      NODE_ENV: development
    image: weatherforecastweb
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3000
        published: "3000"
        protocol: tcp
networks:
  default:
    name: dockercompose15081403233701691846_default
volumes:
  mssql_data:
    name: dockercompose15081403233701691846_mssql_data